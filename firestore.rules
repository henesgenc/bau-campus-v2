rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /campuses/{docId} {
      allow read: if true;
      allow write: if request.auth != null;
    }
    match /blocks/{docId} {
      allow read: if true;
      allow write: if request.auth != null;
    }
    match /classrooms/{docId} {
      allow read: if true;
      allow write: if request.auth != null;
    }
    match /classroomTypes/{docId} {
      allow read: if true;
      allow write: if request.auth != null;
    }
    match /settings/{docId} {
      allow read: if true;
      allow write: if request.auth != null;
    }
  }
}
