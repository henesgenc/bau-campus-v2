rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    match /campuses/{allPaths=**} {
      allow read: if true;
      allow write: if request.auth != null;
    }
    match /blocks/{allPaths=**} {
      allow read: if true;
      allow write: if request.auth != null;
    }
    match /classrooms/{allPaths=**} {
      allow read: if true;
      allow write: if request.auth != null;
    }
    match /settings/{allPaths=**} {
      allow read: if true;
      allow write: if request.auth != null;
    }
  }
}
